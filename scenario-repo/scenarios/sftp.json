{
  "version": 1,
  "name": "SFTP - File Exchange",
  "description": "Stubs an SFTP server. sftp-ok accepts connections with the configured credentials and serves test files. sftp-err rejects all authentication attempts.",
  "adapters": [
    {
      "name": "sftp-ok",
      "type": "SFTP",
      "behavior_mode": "success",
      "config": {
        "files": [
          {
            "name": "/inbound/test-order.xml",
            "content": "<?xml version=\"1.0\"?><Order><OrderNumber>PO-12345</OrderNumber><Vendor>ACME Corp</Vendor><Items><Item><SKU>WIDGET-A</SKU><Qty>100</Qty></Item></Items></Order>"
          },
          {
            "name": "/inbound/test-invoice.xml",
            "content": "<?xml version=\"1.0\"?><Invoice><InvoiceNumber>INV-98765</InvoiceNumber><Amount>4999.00</Amount><Currency>EUR</Currency></Invoice>"
          }
        ],
        "auth_mode": "success"
      },
      "credentials": {
        "username": "cpiuser",
        "password": "cpipass"
      }
    },
    {
      "name": "sftp-err",
      "type": "SFTP",
      "behavior_mode": "failure",
      "config": {
        "files": [],
        "auth_mode": "failure"
      },
      "credentials": {
        "username": "cpiuser",
        "password": "cpipass"
      }
    }
  ]
}
