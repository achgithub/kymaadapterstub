{
  "version": 1,
  "name": "B2B Integration Stack",
  "description": "A multi-adapter scenario combining REST, SFTP, and SOAP stubs. Demonstrates testing a complete integration flow where CPI fetches a file via SFTP, calls a SOAP backend, and exposes a REST status endpoint.",
  "adapters": [
    {
      "name": "b2b-rest-ok",
      "type": "REST",
      "behavior_mode": "success",
      "config": {
        "status_code": 200,
        "response_body": "{\"status\":\"processed\",\"orderId\":\"ORD-20240401-001\",\"message\":\"Order received and queued for processing\"}",
        "response_headers": {
          "Content-Type": "application/json"
        }
      }
    },
    {
      "name": "b2b-rest-err",
      "type": "REST",
      "behavior_mode": "failure",
      "config": {
        "status_code": 503,
        "response_body": "{\"status\":\"error\",\"message\":\"Service temporarily unavailable. Retry after 60 seconds.\"}",
        "response_headers": {
          "Content-Type": "application/json",
          "Retry-After": "60"
        }
      }
    },
    {
      "name": "b2b-sftp-ok",
      "type": "SFTP",
      "behavior_mode": "success",
      "config": {
        "files": [
          {
            "name": "/inbound/order-batch-001.xml",
            "content": "<?xml version=\"1.0\"?><Orders><Order><OrderNumber>ORD-001</OrderNumber><Vendor>ACME</Vendor><Amount>1250.00</Amount></Order><Order><OrderNumber>ORD-002</OrderNumber><Vendor>ACME</Vendor><Amount>875.50</Amount></Order></Orders>"
          }
        ],
        "auth_mode": "success"
      },
      "credentials": {
        "username": "b2buser",
        "password": "b2bpass"
      }
    },
    {
      "name": "b2b-sftp-err",
      "type": "SFTP",
      "behavior_mode": "failure",
      "config": {
        "files": [],
        "auth_mode": "failure"
      },
      "credentials": {
        "username": "b2buser",
        "password": "b2bpass"
      }
    },
    {
      "name": "b2b-soap-ok",
      "type": "SOAP",
      "behavior_mode": "success",
      "config": {
        "status_code": 200,
        "soap_version": "1.1",
        "response_body": "",
        "response_headers": {}
      }
    },
    {
      "name": "b2b-soap-err",
      "type": "SOAP",
      "behavior_mode": "failure",
      "config": {
        "status_code": 500,
        "soap_version": "1.1",
        "response_body": "<?xml version=\"1.0\" encoding=\"UTF-8\"?><soap:Envelope xmlns:soap=\"http://schemas.xmlsoap.org/soap/envelope/\"><soap:Body><soap:Fault><faultcode>soap:Server</faultcode><faultstring>Backend processing failed: order validation error</faultstring></soap:Fault></soap:Body></soap:Envelope>",
        "response_headers": {
          "Content-Type": "text/xml"
        }
      }
    }
  ]
}
